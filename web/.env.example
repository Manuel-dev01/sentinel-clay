# Sentinel web - environment template. Copy to `.env.local` and fill in.
# The app runs without the blanks (demo wallet + heuristic agent fallbacks).

# On-chain (testnet defaults shipped in code; override to point at a new build)
NEXT_PUBLIC_SENTINEL_PKG=0x98164c30fe76cbfec0f822083d1a4e37ffba49af9c2257e3b9d3f2f04b74a7f1
NEXT_PUBLIC_APP_REGISTRY=0x0bdb186a4f3bc18b6a54689c437f57cd4d481694b64daf60d2d871f77858468f

# Enoki zkLogin + sponsored gas - https://portal.enoki.mystenlabs.com
NEXT_PUBLIC_ENOKI_API_KEY=
ENOKI_SECRET_KEY=

# Google OAuth 2.0 Web client ID - https://console.cloud.google.com (register it in Enoki too)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# DeepSeek "Yield Hunter" agent (server-only) - https://platform.deepseek.com
DEEPSEEK_API_KEY=
