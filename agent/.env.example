# Sentinel autonomous Yield Hunter worker · config
# The worker holds NO key and never signs. These are read-only RPC + a feed store + an optional LLM key.

# Sui RPC (defaults to the public testnet fullnode if unset)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# The demo mandate the agent hunts against (the shared object id from arming a mandate in the app)
AGENT_MANDATE_ID=0x...

# Optional: with a key the proposal amount + rationale vary tick-to-tick (LLM). Without it, the
# deterministic heuristic is used (which looks canned).
DEEPSEEK_API_KEY=

# Upstash Redis (free tier) · the proposal feed shared with the web app
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Loop tuning
TICK_MS=12000
ROGUE_EVERY=6
# Cap each proposal's size (SUI) so any faucet-funded user can afford the coin input when approving.
AGENT_MAX_SUI=0.05
